# Docker and cross-platform transcription settings.
TRANSCRIPTION_BACKEND=auto
WHISPER_MODEL=large-v3
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

# File-based secret variants for Docker or mounted secret files.
HF_ACCESS_TOKEN_FILE=
GEMINI_API_KEY_FILE=
LLM_API_KEY_FILE=
